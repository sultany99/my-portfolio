  <script>
    const menuBtn = document.getElementById('menuOpen');
    const mobilePanel = document.getElementById('mobilePanel');
    function toggleMobile() {
      const open = mobilePanel.classList.toggle('open');
      menuBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      menuBtn.textContent = open ? '✕' : '☰';
      document.body.style.overflow = open ? 'hidden' : '';
    }
    menuBtn.addEventListener('click', toggleMobile);
    document.querySelectorAll('.mp-link, .mp-cta').forEach(a => a.addEventListener('click', () => {
      mobilePanel.classList.remove('open');
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.textContent = '☰';
      document.body.style.overflow = '';
    }));

    const slides = document.querySelectorAll('.slide');
    const curEl = document.getElementById('curSlide');
    const progress = document.getElementById('heroProgress');
    let active = 0;
    let timer;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function goTo(i) {
      slides[active].classList.remove('active');
      active = (i + slides.length) % slides.length;
      slides[active].classList.add('active');
      curEl.textContent = String(active + 1).padStart(2, '0');
      restartProgress();
    }
    function restartProgress() {
      progress.style.transition = 'none';
      progress.style.width = '0%';
      requestAnimationFrame(() => {
        progress.style.transition = 'width 6s linear';
        progress.style.width = '100%';
      });
    }
    function startAuto() {
      if (reduceMotion) return;
      clearInterval(timer);
      timer = setInterval(() => goTo(active + 1), 6000);
      restartProgress();
    }
    document.getElementById('nextSlide').addEventListener('click', () => { goTo(active + 1); startAuto(); });
    document.getElementById('prevSlide').addEventListener('click', () => { goTo(active - 1); startAuto(); });
    startAuto();

    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // active state for the heading bar
    const navLinkEls = document.querySelectorAll('.nav-links a');
    const navSectionIds = ['vision', 'experience', 'services', 'projects', 'news'];
    const navIo = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        navLinkEls.forEach(l => l.classList.remove('active'));
        const link = document.querySelector('.nav-links a[data-target="' + entry.target.id + '"]');
        if (link) link.classList.add('active');
      });
    }, { threshold: 0.4, rootMargin: '-80px 0px -60% 0px' });
    navSectionIds.forEach(id => {
      const el = document.getElementById(id);
      if (el) navIo.observe(el);
    });
  </script>

